# OpenCode Go API (LLM - DeepSeek V4 Flash)
OPENCODE_GO_API_KEY=sk-...

# Embedding provider: "nvidia" (default) or "local"
# - "nvidia": NVIDIA NIM API (needs NVIDIA_API_KEY below)
# - "local": fastembed ONNX (BAAI/bge-m3), no API key, lightweight
#   install: pip install ".[local]"
#   When switching providers, reset ChromaDB: --reset flag on build scripts.
# EMBEDDING_PROVIDER=nvidia

# NVIDIA API (Embeddings - nvidia/llama-nemotron-embed-vl-1b-v2)
# Only needed when EMBEDDING_PROVIDER=nvidia (default).
NVIDIA_API_KEY=nvapi-...

# Local embedding model (only when EMBEDDING_PROVIDER=local)
# Default: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384d)
# LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
